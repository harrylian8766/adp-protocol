{
  "name": "adp-sdk",
  "version": "1.1.0",
  "description": "Agent Discovery Protocol (ADP) v1.1 — Node.js reference implementation (SVCB-first, DANE, DNS-AID aligned)",
  "main": "src/index.js",
  "bin": {
    "adp-cli": "./bin/adp-cli.js"
  },
  "type": "module",
  "scripts": {
    "agent-host": "node examples/agent-host/server.js",
    "discover": "node examples/discover-agent.js",
    "keygen": "node bin/adp-cli.js keygen",
    "dns-gen": "node bin/adp-cli.js dns-gen"
  },
  "keywords": [
    "agent",
    "discovery",
    "dns",
    "svcb",
    "tlsa",
    "dns-aid",
    "adp",
    "openclaw"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^2.2.0",
    "express": "^4.18.0",
    "ws": "^8.16.0"
  }
}
