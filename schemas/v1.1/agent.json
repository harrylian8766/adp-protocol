{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/harrylian8766/adp-protocol/main/schemas/v1.1/agent.json",
  "title": "ADP Agent Metadata",
  "description": "JSON Schema for ADP v1.1 agent.json — Agent Discovery Protocol agent metadata document",
  "type": "object",
  "required": ["protocol", "identity", "endpoints", "capabilities"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "This schema's URI"
    },
    "protocol": {
      "type": "string",
      "enum": ["ADP/1.1"],
      "description": "Protocol version identifier"
    },
    "identity": {
      "type": "object",
      "required": ["id", "publicKey"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^agent:[a-z0-9]([a-z0-9-]*[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]*[a-z0-9])?)*$",
          "description": "Agent ID, e.g. agent:alice.example.com"
        },
        "domain": {
          "type": "string",
          "format": "hostname",
          "description": "Fully qualified domain name"
        },
        "name": {
          "type": "string",
          "description": "Human-readable agent name"
        },
        "owner": {
          "type": "string",
          "description": "Owner or organization name"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "publicKey": {
          "type": "object",
          "required": ["algorithm", "fingerprint"],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["ed25519"],
              "description": "Public key algorithm"
            },
            "fingerprint": {
              "type": "string",
              "pattern": "^ed25519:[A-Za-z0-9_=-]+$",
              "description": "SHA-256 fingerprint, base64url-encoded"
            },
            "full": {
              "type": "string",
              "description": "Full SPKI-encoded public key (base64url)"
            },
            "proof": {
              "type": "string",
              "description": "Optional cryptographic proof of ownership"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "endpoints": {
      "type": "object",
      "properties": {
        "discovery": {
          "type": "string",
          "format": "uri",
          "description": "Interactive discovery endpoint (HTML landing page)"
        },
        "wellKnown": {
          "type": "string",
          "format": "uri",
          "description": "Self-reference to this agent.json document"
        },
        "chat": {
          "type": "string",
          "format": "uri",
          "description": "WebSocket/SSE real-time chat endpoint"
        },
        "tasks": {
          "type": "string",
          "format": "uri",
          "description": "REST API for asynchronous tasks"
        },
        "swarm": {
          "type": "string",
          "format": "uri",
          "description": "Multi-agent collaboration endpoint"
        },
        "webhook": {
          "type": "string",
          "format": "uri",
          "description": "External event callback endpoint"
        }
      },
      "additionalProperties": true,
      "minProperties": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique capability identifier"
          },
          "name": {
            "type": "string",
            "description": "Human-readable capability name"
          },
          "description": {
            "type": "string"
          },
          "input": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Supported input modalities"
          },
          "output": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Supported output modalities"
          },
          "interfaces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Interface types (chat, api, etc.)"
          },
          "languages": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Supported languages (ISO 639-1)"
          },
          "pricing": {
            "type": "object",
            "properties": {
              "model": { "type": "string" },
              "details": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    },
    "interfaces": {
      "type": "object",
      "properties": {
        "html": {
          "type": "string",
          "format": "uri",
          "description": "Human-friendly HTML interface"
        },
        "api": {
          "type": "string",
          "format": "uri",
          "description": "REST API base URL"
        },
        "chat": {
          "type": "string",
          "format": "uri",
          "description": "WebSocket/SSE chat interface"
        }
      },
      "additionalProperties": true
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id"],
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "name": { "type": "string" },
          "trust": { "type": "string" },
          "since": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "tlsRequired": {
          "type": "boolean",
          "description": "TLS is mandatory"
        },
        "minProtocolVersion": {
          "type": "string",
          "description": "Minimum ADP version required"
        },
        "authMethods": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported authentication methods (pubkey, dane)"
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "requestsPerMinute": { "type": "integer", "minimum": 1 },
            "burstSize": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "dns": {
      "type": "object",
      "properties": {
        "svcbRecord": {
          "type": "string",
          "description": "SVCB service binding domain or record"
        },
        "tlsaRecord": {
          "type": "string",
          "description": "TLSA DANE record data"
        },
        "dnssec": {
          "type": "boolean",
          "description": "DNSSEC is enabled for this domain"
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "type": "object",
      "properties": {
        "privacy": { "type": "string", "format": "uri" },
        "terms": { "type": "string", "format": "uri" },
        "dataRetention": { "type": "string" },
        "thirdPartySharing": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "availability": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "uptime": { "type": "string" },
        "maintenanceWindow": { "type": "string" },
        "statusEndpoint": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "properties": {
        "updated": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "generator": { "type": "string" },
        "documentation": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
